# football-data.org — https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your_token_here

# LLM — same pattern as SpeakFlow (OpenAI SDK, OpenRouter optional)
# OpenRouter key: sk-or-... from https://openrouter.ai/keys
# Direct OpenAI key: sk-...
OPENAI_API_KEY=your_openai_key_here
# Auto-detected for sk-or-... keys; override if needed:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Gemini via OpenRouter (default):
OPENAI_CHAT_MODEL=google/gemini-2.0-flash-001
APP_URL=http://localhost:8000

# App — Supabase pooler (IPv4, recomendado no Windows). Dashboard → Database → Connection pooling → Session.
# NÃO use db.PROJECT.supabase.co no dev local — esse host é IPv6-only e quebra no Windows.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DEBUG=false
APP_TIMEZONE=America/Sao_Paulo